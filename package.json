{
  "name": "@talkohavy/charts",
  "private": true,
  "version": "2.0.3",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "vite --config vite.config.webapp.ts",
    "clean": "rm -rf node_modules",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "tsc": "tsc -p tsconfig.package.json --noEmit",
    "tsc:app": "tsc -p tsconfig.app.json",
    "format-check": "prettier . --check --config .prettierrc.mjs --ignore-path .prettierignore",
    "format": "prettier . --write --log-level silent --config .prettierrc.json --ignore-path .prettierignore",
    "format:biome": "biome format ./src",
    "format:biome:fix": "biome format --verbose ./src --write",
    "test": "node --test",
    "build": "node build.config.js",
    "build-webapp": "vite build --config vite.config.webapp.ts",
    "prepublishOnly": "npm run build",
    "preview": "vite preview --config vite.config.package.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "restricted"
  },
  "sideEffects": ["**/*.css"],
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "dependencies": {
    "recharts": "3.8.1"
  },
  "homepage": "https://talkohavy.github.io/charts/"
}
